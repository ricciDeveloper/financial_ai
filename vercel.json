{
    "version": 2,
    "builds": [
        {
            "src": "apps/backend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "apps/frontend/package.json",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/apps/backend/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/apps/frontend/$1"
        }
    ]
}