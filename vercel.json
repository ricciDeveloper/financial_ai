{
    "version": 2,
    "builds": [
        {
            "src": "apps/backend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "apps/frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/apps/backend/api/$1"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/apps/frontend/assets/$1"
        },
        {
            "src": "/(index\\.html|favicon\\.ico|manifest\\.json|robots\\.txt)",
            "dest": "/apps/frontend/$1"
        },
        {
            "src": "/(.*)\\.(ico|png|jpg|svg|css|js|json|webmanifest|woff|woff2)",
            "dest": "/apps/frontend/$1.$2"
        },
        {
            "src": "/(.*)",
            "dest": "/apps/frontend/index.html"
        }
    ]
}