{
  "name": "finance-chat-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @finance/backend\" \"npm run dev -w @finance/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}